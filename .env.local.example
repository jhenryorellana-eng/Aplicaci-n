# =====================================================================
# Variables de entorno — copia este archivo a .env.local y rellénalas.
# NUNCA subas .env.local al repositorio.
# =====================================================================

# --- Supabase (panel del proyecto → Project Settings → API) ---
# Públicas (se exponen al navegador, está bien):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreta — SOLO servidor. Nunca exponer al cliente:
SUPABASE_SERVICE_ROLE_KEY=

# --- Mux (dashboard.mux.com) ---
# Access Token (Settings → Access Tokens) — SOLO servidor:
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Signing Key para firmar URLs de reproducción (Settings → Signing Keys) — SOLO servidor:
MUX_SIGNING_KEY_ID=
# Clave privada del Signing Key en base64 (una sola línea) — SOLO servidor:
MUX_SIGNING_PRIVATE_KEY=
# Secreto del webhook (Settings → Webhooks) — SOLO servidor:
MUX_WEBHOOK_SECRET=

# --- App ---
# URL pública del sitio (para metadatos / enlaces absolutos):
NEXT_PUBLIC_SITE_URL=http://localhost:3000
